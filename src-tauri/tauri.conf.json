{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Easy Start",
  "version": "1.1.5",
  "identifier": "com.easystart.dev",
  "build": {
    "frontendDist": "../dist/easy-start/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Easy Start",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "desktop-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCMUQ5MTQxMjZBNzg5REYKUldUZmlhY21RWkVkRzlnV3l5NUtGMHNtWnoyQ2dZUnltVnBXOGkyTkNmQ0Q2M2FkR2ZSVmV1MG4K",
      "endpoints": [
        "https://github.com/vssoares/easy-start/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

